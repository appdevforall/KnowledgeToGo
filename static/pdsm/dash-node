#!/bin/sh
# /usr/local/pdsm/services-available/dash-node
# PDSM service wrapper for the IIAB-oA Dashboard (Node.js).
# ADFA-4839: run the COMPILED JS (dist/server.js) instead of `ts-node server.ts`,
# with a small respawn supervisor and a health probe.

PDSM_COMMON="/usr/local/pdsm/lib/pdsm-common.sh"
[ -r "$PDSM_COMMON" ] && . "$PDSM_COMMON"

SERVICE_NAME="dash-node"
APP_DIR="/library/dashboard"
ENTRY="dist/server.js"
LOGFILE="/var/log/dash-node.log"
SUP_PIDFILE="/var/run/dash-node.sup.pid"

running() {
  # Match the actual server process, not the supervisor shell.
  pgrep -f "node $ENTRY" >/dev/null 2>&1
}

start() {
  if running; then
    echo "[pdsm:$SERVICE_NAME] already running"
    return 0
  fi

  echo "[pdsm:$SERVICE_NAME] starting..."
  cd "$APP_DIR" || return 1

  # Supervisor: respawn the server if it exits. Its PID is recorded so stop() can end
  # the respawn loop before killing the server. ENTRY/LOGFILE are passed via the env so
  # the inner shell expands them at runtime (avoids brittle nested quoting).
  ENTRY="$ENTRY" LOGFILE="$LOGFILE" nohup sh -c \
    'while :; do node "$ENTRY" >> "$LOGFILE" 2>&1; echo "[dash-node] exited ($?); respawning in 2s" >> "$LOGFILE"; sleep 2; done' \
    >/dev/null 2>&1 &
  echo $! > "$SUP_PIDFILE"

  for i in $(seq 1 "${PDSM_START_TIMEOUT:-8}"); do
    if running; then
      echo "[pdsm:$SERVICE_NAME] started"
      return 0
    fi
    sleep 1
  done

  echo "[pdsm:$SERVICE_NAME] failed to start" >&2
  return 1
}

stop() {
  # Kill the supervisor first so it stops respawning, then the server itself.
  if [ -f "$SUP_PIDFILE" ]; then
    kill "$(cat "$SUP_PIDFILE")" 2>/dev/null || true
    rm -f "$SUP_PIDFILE"
  fi

  if ! running; then
    echo "[pdsm:$SERVICE_NAME] already stopped"
    return 0
  fi

  echo "[pdsm:$SERVICE_NAME] stopping..."
  pkill -f "node $ENTRY" 2>/dev/null || true

  for i in $(seq 1 "${PDSM_START_TIMEOUT:-5}"); do
    if ! running; then
      echo "[pdsm:$SERVICE_NAME] stopped"
      return 0
    fi
    sleep 1
  done

  pkill -9 -f "node $ENTRY" 2>/dev/null || true
  echo "[pdsm:$SERVICE_NAME] forced stop"
  return 1
}

status() {
  if running; then
    echo "[pdsm:$SERVICE_NAME] running (PID: $(pgrep -f "node $ENTRY" | head -n 1))"
    return 0
  fi
  echo "[pdsm:$SERVICE_NAME] not running"
  return 3
}

health() {
  # Liveness: the REST API answers 2xx on loopback (the jobs list is always 200).
  if command -v curl >/dev/null 2>&1 && \
     curl -fs -o /dev/null "http://127.0.0.1:4000/api/kiwix/jobs"; then
    echo "[pdsm:$SERVICE_NAME] healthy"
    return 0
  fi
  echo "[pdsm:$SERVICE_NAME] unhealthy"
  return 1
}

case "$1" in
  start|stop|status|health) "$1" ;;
  restart) stop; start ;;
  *) echo "Usage: $0 {start|stop|restart|status|health}" >&2; exit 1 ;;
esac
