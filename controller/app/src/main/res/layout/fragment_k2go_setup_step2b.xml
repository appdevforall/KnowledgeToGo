<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/k2go_paper">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:id="@+id/k2go_step2_title" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/k2go_setup_library_title" android:textAppearance="?attr/textAppearanceHeadlineMedium" android:textColor="@color/k2go_ink" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp"
            android:text="@string/k2go_step2b_breadcrumb" android:textAppearance="?attr/textAppearanceBodyLarge" android:textColor="@color/k2go_teal" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
            android:layout_marginTop="14dp" android:gravity="center">
            <TextView android:id="@+id/k2go_sd0" android:layout_width="34dp" android:layout_height="34dp" android:gravity="center" android:text="1" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/k2go_sd1" android:layout_width="34dp" android:layout_height="34dp" android:gravity="center" android:text="2" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/k2go_sd2" android:layout_width="34dp" android:layout_height="34dp" android:gravity="center" android:text="3" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/k2go_sd3" android:layout_width="34dp" android:layout_height="34dp" android:gravity="center" android:text="4" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/k2go_sd4" android:layout_width="34dp" android:layout_height="34dp" android:gravity="center" android:text="5" />
        </LinearLayout>
        <TextView android:id="@+id/k2go_step_caption" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:textAppearance="?attr/textAppearanceTitleLarge" android:textColor="@color/k2go_ink" />

        <org.iiab.controller.MultiResourceGaugeView android:id="@+id/k2go_gauge"
            android:layout_width="match_parent" android:layout_height="210dp" android:layout_marginTop="10dp" />
        <TextView android:id="@+id/k2go_legend" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="6dp" android:textAppearance="?attr/textAppearanceBodySmall" android:textColor="@color/k2go_muted" />

        <LinearLayout android:id="@+id/k2go_wiki_block" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginTop="16dp" android:padding="14dp" android:background="@drawable/k2go_card_bg">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/k2go_coverage"
                android:textAppearance="?attr/textAppearanceBodySmall" android:textColor="@color/k2go_muted" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                <TextView android:id="@+id/k2go_cov_popular" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp" android:padding="10dp" android:gravity="center" android:text="@string/k2go_cov_popular" android:clickable="true" android:focusable="true" />
                <TextView android:id="@+id/k2go_cov_everything" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:padding="10dp" android:gravity="center" android:text="@string/k2go_cov_everything" android:clickable="true" android:focusable="true" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/k2go_detail"
                android:textAppearance="?attr/textAppearanceBodySmall" android:textColor="@color/k2go_muted" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                <TextView android:id="@+id/k2go_det_pictures" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp" android:padding="10dp" android:gravity="center" android:text="@string/k2go_det_pictures" android:clickable="true" android:focusable="true" />
                <TextView android:id="@+id/k2go_det_text" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:padding="10dp" android:gravity="center" android:text="@string/k2go_det_text" android:clickable="true" android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:id="@+id/k2go_info_text" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:textAppearance="?attr/textAppearanceBodyLarge" android:textColor="@color/k2go_muted" android:visibility="gone" />

        <TextView android:id="@+id/k2go_btn_next" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:padding="16dp" android:gravity="center" android:text="@string/k2go_next"
            android:textAppearance="?attr/textAppearanceTitleLarge" android:textColor="@color/k2go_on_teal" android:background="@drawable/k2go_primary_bg" android:clickable="true" android:focusable="true" />
        <TextView android:id="@+id/k2go_btn_back" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="10dp" android:padding="8dp" android:gravity="center" android:text="@string/k2go_back_link"
            android:textAppearance="?attr/textAppearanceBodyLarge" android:textColor="@color/k2go_teal" android:clickable="true" android:focusable="true" />
    </LinearLayout>
</ScrollView>
