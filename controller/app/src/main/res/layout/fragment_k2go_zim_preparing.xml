<?xml version="1.0" encoding="utf-8"?>
<!-- ADFA-4849: ZIM Preparing (screen 4). Contained placeholder animation (independent of the
     boot/close Lottie) + a REAL progress bar/percent + "X of N items" + per-category checklist.
     Mock progress until the download backend is wired. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/k2go_zim_preparing_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/k2go_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/k2go_zim_preparing_sub"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/k2go_muted" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginTop="12dp">

            <ProgressBar
                android:id="@+id/k2go_zprep_anim"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/k2go_teal" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/k2go_zprep_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/k2go_ink" />

            <TextView
                android:id="@+id/k2go_zprep_pct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/k2go_ink" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/k2go_zprep_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:max="100"
            android:progressTint="@color/k2go_teal"
            android:progressBackgroundTint="@color/k2go_hairline" />

        <TextView
            android:id="@+id/k2go_zprep_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/k2go_muted" />

        <LinearLayout
            android:id="@+id/k2go_zprep_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@drawable/k2go_info_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/k2go_zim_leave_title"
                android:textStyle="bold"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="@color/k2go_teal" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/k2go_zim_leave_body"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/k2go_teal" />
        </LinearLayout>

        <Button
            android:id="@+id/k2go_zprep_run_bg"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:text="@string/k2go_zim_run_bg"
            android:textColor="@color/k2go_teal"
            android:textAllCaps="false"
            android:background="@drawable/k2go_getmore_bg" />
    </LinearLayout>
</ScrollView>
