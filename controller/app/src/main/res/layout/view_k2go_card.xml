<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:layout_margin="8dp"
    android:padding="16dp"
    android:minHeight="150dp"
    android:background="@drawable/k2go_card_bg"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/k2go_card_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        app:tint="@color/k2go_teal"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/k2go_card_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="@color/k2go_ink" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/k2go_card_dot"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:background="@drawable/k2go_dot" />

        <TextView
            android:id="@+id/k2go_card_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/k2go_muted" />
    </LinearLayout>
</LinearLayout>
