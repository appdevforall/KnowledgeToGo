<?xml version="1.0" encoding="utf-8"?>
<!-- ADFA-4848: Get More hub — the content catalog entry. Header + a 2-column grid of
     content-type cards, filled programmatically by GetMoreHubFragment. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/k2go_gm_hub_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/k2go_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/k2go_gm_hub_sub"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/k2go_muted" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/k2go_gm_hub_prompt"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/k2go_ink" />

        <LinearLayout
            android:id="@+id/k2go_gm_cards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
