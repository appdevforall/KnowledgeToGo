<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/k2go_paper" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:id="@+id/wiz_title" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:textAppearance="?attr/textAppearanceHeadlineMedium" android:textColor="@color/k2go_ink" />
        <TextView android:id="@+id/wiz_subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="6dp" android:textAppearance="?attr/textAppearanceBodyLarge" android:textColor="@color/k2go_muted" />

        <!-- WELCOME -->
        <LinearLayout android:id="@+id/wiz_welcome" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginTop="24dp" android:gravity="center">
            <View android:layout_width="match_parent" android:layout_height="72dp" />
            <ImageView android:layout_width="150dp" android:layout_height="150dp"
                android:src="@drawable/splash_logo" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="20dp" android:gravity="center" android:text="@string/k2go_brand"
                android:textAppearance="?attr/textAppearanceHeadlineMedium" android:textColor="@color/k2go_ink" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="6dp" android:gravity="center" android:text="@string/k2go_welcome_sub"
                android:textAppearance="?attr/textAppearanceBodyLarge" android:textColor="@color/k2go_muted" />
        </LinearLayout>

        <!-- LANGUAGE -->
        <LinearLayout android:id="@+id/wiz_language" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginTop="20dp" android:visibility="gone">
            <LinearLayout android:id="@+id/lang_system" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
                android:gravity="center_vertical" android:padding="14dp" android:layout_marginTop="8dp" android:background="@drawable/k2go_card_bg" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/lang_system_radio" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_radio_on" android:contentDescription="@null" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="@string/k2go_lang_system_default" android:textColor="@color/k2go_ink" android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>
            <LinearLayout android:id="@+id/lang_en" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
                android:gravity="center_vertical" android:padding="14dp" android:layout_marginTop="8dp" android:background="@drawable/k2go_card_bg" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/lang_en_radio" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_radio_off" android:contentDescription="@null" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="@string/k2go_lang_english" android:textColor="@color/k2go_ink" android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>
            <LinearLayout android:id="@+id/lang_es" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
                android:gravity="center_vertical" android:padding="14dp" android:layout_marginTop="8dp" android:background="@drawable/k2go_card_bg" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/lang_es_radio" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_radio_off" android:contentDescription="@null" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="@string/k2go_lang_spanish" android:textColor="@color/k2go_ink" android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>
        </LinearLayout>

        <!-- PERMISSIONS -->
        <LinearLayout android:id="@+id/wiz_perms" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginTop="20dp" android:visibility="gone">
            <LinearLayout android:id="@+id/perm_notif" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
                android:gravity="center_vertical" android:padding="14dp" android:layout_marginTop="8dp" android:background="@drawable/k2go_card_bg" android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/k2go_perm_notifications" android:textColor="@color/k2go_ink" android:textAppearance="?attr/textAppearanceBodyLarge" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/k2go_perm_notifications_sub" android:textColor="@color/k2go_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
                </LinearLayout>
                <TextView android:id="@+id/perm_notif_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/k2go_perm_allow" android:textColor="@color/k2go_teal" />
            </LinearLayout>
            <LinearLayout android:id="@+id/perm_storage" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
                android:gravity="center_vertical" android:padding="14dp" android:layout_marginTop="8dp" android:background="@drawable/k2go_card_bg" android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/k2go_perm_storage" android:textColor="@color/k2go_ink" android:textAppearance="?attr/textAppearanceBodyLarge" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/k2go_perm_storage_sub" android:textColor="@color/k2go_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
                </LinearLayout>
                <TextView android:id="@+id/perm_storage_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/k2go_perm_allow" android:textColor="@color/k2go_teal" />
            </LinearLayout>
            <LinearLayout android:id="@+id/perm_battery" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
                android:gravity="center_vertical" android:padding="14dp" android:layout_marginTop="8dp" android:background="@drawable/k2go_card_bg" android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/k2go_perm_keep_running" android:textColor="@color/k2go_ink" android:textAppearance="?attr/textAppearanceBodyLarge" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/k2go_perm_keep_running_sub" android:textColor="@color/k2go_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
                </LinearLayout>
                <TextView android:id="@+id/perm_battery_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/k2go_perm_allow" android:textColor="@color/k2go_teal" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp"
                android:text="@string/k2go_perm_nearby_note" android:textColor="@color/k2go_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
        </LinearLayout>

        <!-- SET UP LIBRARY -->
        <LinearLayout android:id="@+id/wiz_setup" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginTop="20dp" android:visibility="gone">
            <TextView android:id="@+id/setup_download" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp"
                android:gravity="center" android:text="@string/k2go_internet_download" android:background="@drawable/k2go_primary_bg" android:textColor="@color/k2go_on_teal" android:textAppearance="?attr/textAppearanceTitleLarge" android:clickable="true" android:focusable="true" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:layout_marginTop="4dp"
                android:text="@string/k2go_internet_download_sub" android:textColor="@color/k2go_muted" android:textAppearance="?attr/textAppearanceBodySmall" />
            <TextView android:id="@+id/setup_copy" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:layout_marginTop="14dp"
                android:gravity="center" android:text="@string/k2go_copy_from_phone" android:background="@drawable/k2go_getmore_bg" android:textColor="@color/k2go_teal" android:textAppearance="?attr/textAppearanceTitleLarge" android:clickable="true" android:focusable="true" />
        </LinearLayout>

        <!-- Push the primary CTA to the bottom (fixed position across steps, per the wizard diagram). -->
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:minHeight="24dp" />

        <TextView android:id="@+id/wiz_primary" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="28dp" android:padding="16dp" android:gravity="center" android:text="@string/k2go_get_started"
            android:background="@drawable/k2go_primary_bg" android:textColor="@color/k2go_on_teal" android:textAppearance="?attr/textAppearanceTitleLarge" android:clickable="true" android:focusable="true" />
    </LinearLayout>
</ScrollView>
