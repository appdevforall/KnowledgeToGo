<?xml version="1.0" encoding="utf-8"?>
<!-- ADFA-4848 (slice 3): Maps Preparing. A CONTAINED placeholder spinner (independent of the
     boot/close Lottie) in a small band, plus a single status line that mirrors what the
     background process is doing (like the boot screen shows the current service). No invented
     progress bar. Mock text until the REST/Ansible backend feeds real output. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/k2go_maps_preparing_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/k2go_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/k2go_maps_preparing_sub"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/k2go_muted" />

        <!-- Contained placeholder animation. A custom Lottie can replace this ProgressBar
             later WITHOUT touching the boot/close animation. -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="16dp">

            <ProgressBar
                android:id="@+id/k2go_prep_anim"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/k2go_teal" />
        </FrameLayout>

        <!-- The process's own text, not an invented percentage. -->
        <TextView
            android:id="@+id/k2go_prep_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/k2go_maps_phase_prepared"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/k2go_ink" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@drawable/k2go_getmore_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/k2go_maps_leave_title"
                android:textStyle="bold"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="@color/k2go_teal" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/k2go_maps_leave_body"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/k2go_teal" />
        </LinearLayout>

        <Button
            android:id="@+id/k2go_prep_run_bg"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:text="@string/k2go_maps_run_bg"
            android:textColor="@color/k2go_teal"
            android:textAllCaps="false"
            android:background="@drawable/k2go_getmore_bg" />
    </LinearLayout>
</ScrollView>
