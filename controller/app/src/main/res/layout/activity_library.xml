<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/k2go_paper">

    <!-- ADFA-4799: rail (leading) + content. The rail is shown and the bottom bar hidden in
         medium/expanded (>= 600dp wide); the reverse in compact. Toggled at runtime by width in
         LibraryActivity, so rotation never recreates the activity (the boot gate is preserved). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <com.google.android.material.navigationrail.NavigationRailView
            android:id="@+id/k2go_nav_rail"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@color/k2go_paper"
            android:visibility="gone"
            app:elevation="0dp"
            app:labelVisibilityMode="labeled"
            app:menuGravity="center"
            app:itemIconTint="@color/k2go_nav_item"
            app:itemTextColor="@color/k2go_nav_item"
            app:menu="@menu/bottom_nav_k2go" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/k2go_nav_host"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/k2go_bottom_nav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/k2go_paper"
                app:elevation="0dp"
                app:labelVisibilityMode="labeled"
                app:itemIconTint="@color/k2go_nav_item"
                app:itemTextColor="@color/k2go_nav_item"
                app:menu="@menu/bottom_nav_k2go" />
        </LinearLayout>
    </LinearLayout>

    <!-- Boot gate: covers the ~5-6s server boot; entry loop then OPEN flip. -->
    <!-- ADFA-4814: fitCenter + horizontal padding so the intro/outro isn't jammed into the
         corners. Background matches the animation's own BG (#FBF8F3 in both themes) so the
         margin reads as continuous. -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/k2go_boot_gate"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/k2go_boot_bg"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="fitCenter" />

    <!-- Install progress over the boot gate: stays until the install actually finishes. -->
    <LinearLayout
        android:id="@+id/k2go_install_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingLeft="28dp"
        android:paddingRight="28dp"
        android:paddingTop="16dp"
        android:paddingBottom="56dp"
        android:elevation="13dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/k2go_install_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/k2go_ink" />

        <ProgressBar
            android:id="@+id/k2go_install_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:max="100"
            android:progressTint="@color/k2go_teal"
            android:progressBackgroundTint="@color/k2go_hairline" />

        <TextView
            android:id="@+id/k2go_install_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/k2go_muted" />
    </LinearLayout>
</FrameLayout>
