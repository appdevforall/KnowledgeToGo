<?xml version="1.0" encoding="utf-8"?>
<!-- ADFA-4849: ZIM Confirm (screen 3). Cross-category breakdown from the cart + total + fit + warning. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/k2go_zconf_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/k2go_teal" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/k2go_zim_confirm_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/k2go_ink" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/k2go_zim_confirm_sub"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/k2go_muted" />

        <LinearLayout
            android:id="@+id/k2go_zconf_breakdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/k2go_card_bg" />

        <TextView
            android:id="@+id/k2go_zconf_fits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:drawablePadding="8dp"
            android:drawableTint="@color/k2go_leaf"
            android:background="@drawable/k2go_ok_bg"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@drawable/k2go_warn_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/k2go_zim_takes_title"
                android:textStyle="bold"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="@color/k2go_amber_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/k2go_zim_takes_body"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/k2go_amber_text" />
        </LinearLayout>

        <Button
            android:id="@+id/k2go_zconf_start"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:backgroundTint="@color/k2go_teal" />
    </LinearLayout>
</ScrollView>
