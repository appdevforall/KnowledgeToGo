<?xml version="1.0" encoding="utf-8"?>
<!-- ADFA-4849: ZIM category detail (screen 2). Variant/title rows built programmatically into
     k2go_zc_list; in-category search + sort; per-item free-space guard; Add-to-selection. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/k2go_zc_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/k2go_teal" />

        <TextView
            android:id="@+id/k2go_zc_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/k2go_ink" />

        <TextView
            android:id="@+id/k2go_zc_sub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/k2go_muted" />

        <EditText
            android:id="@+id/k2go_zc_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@drawable/k2go_card_bg"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/k2go_ink"
            android:textColorHint="@color/k2go_muted" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/k2go_zc_sort_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="@string/k2go_zc_sort_size"
                android:textAppearance="?attr/textAppearanceBodySmall" />

            <TextView
                android:id="@+id/k2go_zc_sort_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="@string/k2go_zc_sort_name"
                android:textAppearance="?attr/textAppearanceBodySmall" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/k2go_zc_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/k2go_zc_free"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/k2go_muted" />

        <ProgressBar
            android:id="@+id/k2go_zc_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:max="100"
            android:progressTint="@color/k2go_teal"
            android:progressBackgroundTint="@color/k2go_hairline" />

        <Button
            android:id="@+id/k2go_zc_add"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:backgroundTint="@color/k2go_teal" />
    </LinearLayout>
</ScrollView>
