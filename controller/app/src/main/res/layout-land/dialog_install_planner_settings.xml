<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/dash_bg_main"
    android:padding="16dp"
    android:baselineAligned="false">

    <!-- Header: explicit close (X), always a way out (ADFA-4658) -->
    <ImageView
        android:id="@+id/btn_planner_close"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="end"
        android:src="@drawable/ic_close_24"
        android:tint="@color/dash_text_secondary"
        android:contentDescription="@string/kiwix_dialog_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp" />

    <!-- Loading state -->
    <LinearLayout
        android:id="@+id/planner_loading"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:indeterminateTint="@color/dash_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/kiwix_dialog_loading"
            android:textColor="@color/dash_text_primary"
            android:textSize="13sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Offline state -->
    <LinearLayout
        android:id="@+id/planner_offline"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/outline_cloud_off_24"
            android:tint="@color/status_danger"
            android:contentDescription="@string/kiwix_dialog_offline" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/kiwix_dialog_offline"
            android:textColor="@color/status_danger"
            android:textSize="13sp"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_planner_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/kiwix_dialog_retry"
            android:textColor="@color/text_on_accent"
            android:textAllCaps="false"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/status_info" />
    </LinearLayout>

    <!-- Ready state: two columns (language | variants) inside a bounded band -->
    <LinearLayout
        android:id="@+id/planner_content"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/kiwix_dialog_lang_label"
                android:textColor="@color/dash_text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinner_kiwix_lang"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/dash_module_bg"
                android:popupBackground="@color/dash_bg_card"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/dash_module_bg"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/kiwix_dialog_variants_label"
                android:textColor="@color/dash_text_primary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <RadioGroup
                    android:id="@+id/rg_kiwix_variants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- Actions: pinned below the band, always visible -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btn_wipe_cache"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/kiwix_dialog_wipe_cache"
            android:textColor="@color/text_on_accent"
            android:textAllCaps="false"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/status_info" />

        <Button
            android:id="@+id/btn_select_variant"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/kiwix_dialog_select"
            android:textColor="@color/text_on_accent"
            android:textAllCaps="false"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/status_success" />
    </LinearLayout>
</LinearLayout>
