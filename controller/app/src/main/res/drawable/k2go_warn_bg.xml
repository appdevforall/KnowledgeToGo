<?xml version="1.0" encoding="utf-8"?>
<!-- ADFA-4784: amber notice for the "these phones aren't compatible" block. Fixed colors in both
     themes (like k2go_notice_bg); body text uses k2go_notice_ink so it reads on the amber fill. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#C98A1E" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:left="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#FBEFD3" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
